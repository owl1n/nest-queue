{
  "name": "nest-queue",
  "version": "2.0.0",
  "description": "Queue module for NestJS applications with Bull",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "packageManager": "pnpm@10.6.2",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rimraf dist && tsc -p tsconfig.json",
    "clean": "rimraf dist coverage",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "coverage": "jest --coverage",
    "format": "prettier \"**/*.{ts,md,json}\" --ignore-path ./.prettierignore --write",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "prepare": "pnpm run build"
  },
  "keywords": [
    "nestjs",
    "typescript",
    "queue",
    "redis"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/owl1n/nest-queue"
  },
  "author": {
    "name": "Markin Maxim",
    "email": "mxrkin@yandex.ru"
  },
  "license": "MIT",
  "peerDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.1.18",
    "bull": "^4.16.5",
    "bullmq": "^5.56.0",
    "rxjs": "^7.8.0"
  },
  "peerDependenciesMeta": {
    "bullmq": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.1.18",
    "@nestjs/testing": "^11.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.10",
    "@eslint/js": "^9.23.0",
    "bull": "^4.16.5",
    "bullmq": "^5.56.0",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.1.1",
    "globals": "^16.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "reflect-metadata": "^0.2.2",
    "rimraf": "^6.0.1",
    "rxjs": "^7.8.2",
    "ts-jest": "^29.2.6",
    "typescript-eslint": "^8.27.0",
    "typescript": "^5.8.2"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".spec.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "testEnvironment": "node",
    "coverageDirectory": "./coverage"
  }
}
